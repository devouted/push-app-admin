  "mcpServers": {
    "redmineQAAgent": {
      "command": "/home/projects/mcp-redmine-docker/run-redmine-mcp-QA.sh",
      "timeout": 60000
    }
  },
  "tools": [
    "fs_read",
    "execute_bash",
